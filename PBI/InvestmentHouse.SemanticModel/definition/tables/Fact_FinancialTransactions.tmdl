table Fact_FinancialTransactions
	lineageTag: 2c6259df-a182-4fc9-b4fe-40d9a608ecc0
	sourceLineageTag: 7f20c669-768b-48c3-bd56-c3492a6a94da










	measure Total_Actual_Amount = SUM(Fact_FinancialTransactions[ActualAmount])
		formatString: R#,##0.00;"(R#,##0.00)";"-"

	measure Total_Budget_Amount = SUM(Fact_FinancialTransactions[BudgetAmount])
		formatString: R#,##0.00;"(R#,##0.00)";"-"

	measure Budget_vs_Actual_Variance_Percent = DIVIDE([Total_Actual_Amount] - [Total_Budget_Amount], [Total_Budget_Amount])
		formatString: 0.00%

	measure YoY_Actual_Opex_Variance_Percent =
			VAR ActualYTD = TOTALYTD([Total_Actual_Amount], Dim_Date[Date])
			VAR PriorYTD = TOTALYTD([Total_Actual_Amount], DATEADD(Dim_Date[Date], -1, YEAR))
			RETURN DIVIDE(ActualYTD - PriorYTD, PriorYTD)
		formatString: 0.00%

	measure PFMA_Irregular_Expenditure_Counter = CALCULATE(COUNTROWS(Fact_FinancialTransactions), Fact_FinancialTransactions[PFMA_Status_Code] > 0)
		formatString: #,##0

	measure Opex_YoY_Variance_Percent =
			VAR CurrentYTD = TOTALYTD(SUM(Fact_FinancialTransactions[ActualAmount]), Dim_Date[Date])
			VAR PriorYTD = TOTALYTD(SUM(Fact_FinancialTransactions[ActualAmount]), DATEADD(Dim_Date[Date], -1, YEAR))
			VAR VarianceValue = CurrentYTD - PriorYTD
			RETURN
				DIVIDE(
					VarianceValue, 
					PriorYTD, 
					0
				)
		formatString: 0.00%

	measure Rolling_12Month_Opex =
			VAR EndDate = MAX(Dim_Date[Date])
			VAR StartDate = EDATE(EndDate, -12) + 1
			VAR CalculationPeriod = 
				FILTER(
					ALL(Dim_Date),
					Dim_Date[Date] >= StartDate && 
					Dim_Date[Date] <= EndDate
				)
			RETURN
				CALCULATE(
					SUM(Fact_FinancialTransactions[ActualAmount]),
					CalculationPeriod
				)
		formatString: R#,##0.00;"(R#,##0.00)";"-"

	measure Division_Expenditure_Share_Percent =
			VAR SelectedDivisionSpend = SUM(Fact_FinancialTransactions[ActualAmount])
			VAR TotalCorporateSpend = 
				CALCULATE(
					SUM(Fact_FinancialTransactions[ActualAmount]),
					ALLSELECTED(Dim_Division)
				)
			RETURN
				DIVIDE(
					SelectedDivisionSpend, 
					TotalCorporateSpend, 
					0
				)
		formatString: 0.00%

	measure Cost_to_Income_Ratio =
			VAR TotalIncome = SUMX(Fact_PortfolioReturns, Fact_PortfolioReturns[MarketValue] * 0.0015)
			RETURN
				DIVIDE(
					SUM(Fact_FinancialTransactions[ActualAmount]),
					TotalIncome,
					0
				)
		formatString: 0.00%
