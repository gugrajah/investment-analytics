table Fact_ProjectMilestones
	lineageTag: c1250cfb-8367-4d49-ac97-edfa4e9a7385
	sourceLineageTag: e61c997b-409a-42aa-85fb-f8aa71b8dc19


	measure Project_Milestone_Adherence_Rate =
			DIVIDE(
				CALCULATE(COUNTROWS(Fact_ProjectMilestones), Fact_ProjectMilestones[Status] = "Completed"), 
				COUNTROWS(Fact_ProjectMilestones), 
				0
			)
		formatString: 0.00%
	column MilestoneKey
