table Fact_AuditFindings
	lineageTag: 7b5c012c-4fae-40b1-a4a5-43239d00ec20
	sourceLineageTag: 01060b89-5b0a-4c32-b44a-b0e4ed54d0c4




	measure Open_Audit_Findings_Count = CALCULATE(COUNTROWS(Fact_AuditFindings), Fact_AuditFindings[IsClosed] = FALSE)
		formatString: #,##0

	measure Average_Days_to_Resolve =
			AVERAGEX(
				FILTER(Fact_AuditFindings, NOT(ISBLANK(Fact_AuditFindings[ActualResolutionDateKey]))),
				DATEDIFF(
					RELATED(Dim_Date[Date]), 
					LOOKUPVALUE(Dim_Date[Date], Dim_Date[DateKey], Fact_AuditFindings[ActualResolutionDateKey]), 
					DAY
				)
			)
		formatString: 0.0

	measure Regulatory_SLA_Compliance_Percent =
			VAR CompliantFindings = 
				CALCULATE(
					COUNTROWS(Fact_AuditFindings),
					FILTER(
						Fact_AuditFindings,
						IF(
							Fact_AuditFindings[IsClosed] = TRUE,
							Fact_AuditFindings[ActualResolutionDateKey] <= Fact_AuditFindings[TargetDateKey],
							Fact_AuditFindings[TargetDateKey] >= 20251231
						)
					)
				)
			RETURN
				DIVIDE(CompliantFindings, COUNTROWS(Fact_AuditFindings), 0)
		formatString: 0.00%
	column FindingKey
		dataType: int64
		formatString: 0
		lineageTag: 59f85e4b-fde4-4c7b-9a48-49f4d5bdfe9c
